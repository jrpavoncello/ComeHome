################################################################################
# .gitignore — tailored for Visual Studio / .NET / WPF projects
# Generated/updated to ignore common build artifacts, user files, and tools
################################################################################

# Visual Studio
.vs/
*.suo
*.user
*.userosscache
*.sln.docstates

# Build results
[Bb]in/
[Oo]bj/
artifacts/

# Rider / JetBrains
.idea/
*.sln.iml

# Visual Studio Code
.vscode/

# NuGet
packages/
*.nupkg
.nuget/
.nuget/packages/
project.lock.json

# ReSharper
_ReSharper*/
*.DotSettings.user
*.DotSettings

# OS generated files
Thumbs.db
ehthumbs.db
Desktop.ini
.DS_Store

# Logs
*.log
logs/

# Test results
TestResults/
*.trx
*.coverage
coverage/

# Publish / deployment
publish/
PublishedOutput/
out/
dist/

# Installer build output
installer/bin/
installer/obj/
installer/Release/
installer/Debug/

# Package managers
node_modules/
jspm_packages/

# Certificates and secrets
*.pfx
*.p12
*.key
*.pem
secrets.json
.env
.env.*

# Database files
*.mdf
*.ldf

# Temporary files
*.tmp
*.temp
~$*

# Backup & lock files
*.bak
*.old
*.orig
*.lock

# Generated files
*.generated.cs
*.g.cs
*.Designer.cs

# Coverage & profiling
*.coverage
coverage*/
*.prof

# Docker
.docker/
Dockerfile.*.local

# NPM logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Ignore compiled Python files (if any tools use Python)
__pycache__/
*.py[cod]

# Ensure the .gitignore itself is tracked
!/.gitignore
