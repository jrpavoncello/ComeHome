<UserControl x:Class="ComeHome.App.Controls.TimePicker"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <StackPanel Orientation="Horizontal">
        <ComboBox x:Name="HourCombo"
                  Width="44" Height="22"
                  FontSize="11" Padding="3,1"
                  VerticalContentAlignment="Center"
                  SelectionChanged="OnTimeChanged"/>
        <TextBlock Text=":"
                   VerticalAlignment="Center"
                   Margin="1,0" FontSize="11"
                   FontWeight="SemiBold"
                   Foreground="#2E4057"/>
        <ComboBox x:Name="MinuteCombo"
                  Width="44" Height="22"
                  FontSize="11" Padding="3,1"
                  VerticalContentAlignment="Center"
                  SelectionChanged="OnTimeChanged"/>
    </StackPanel>
</UserControl>
